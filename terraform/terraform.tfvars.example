# Copy to terraform.tfvars (git-ignored) and adjust. Or keep per-environment
# files: dev.tfvars, staging.tfvars, prod.tfvars, and pass with -var-file=.

environment        = "dev"
aws_region         = "us-east-1"
project_name       = "devops-assessment"
kubernetes_version = "1.30"

# Node group (size + count)
node_instance_type = "t3.medium"
node_desired_count = 2
node_min_count     = 2
node_max_count     = 4

# Network
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]

# Database
db_instance_class    = "db.t3.micro"
db_engine_version    = "16.3"
db_allocated_storage = 20
db_multi_az          = false # set true for prod
