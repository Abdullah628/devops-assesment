# Copy to backend.hcl and fill in your values, then:
#   terraform init -backend-config=backend.hcl
#
# We use ONE backend + Terraform WORKSPACES (dev, staging, prod). Each workspace
# stores its state under a separate  env:/<workspace>/  prefix in the SAME bucket,
# so environments are fully isolated without needing a separate backend per env.
#
# The bucket and DynamoDB table must already exist (one-time bootstrap — see the
# environments runbook: docs/environments.md).

bucket         = "my-tf-state-bucket-CHANGE_ME"
key            = "devops-assessment/terraform.tfstate"
region         = "eu-north-1"
dynamodb_table = "my-tf-locks-CHANGE_ME"
encrypt        = true
