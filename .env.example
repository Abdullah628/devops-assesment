# Copy to `.env` and adjust for local development: `cp .env.example .env`
# The real `.env` is git-ignored and must never be committed.
# In Kubernetes/production these values come from a ConfigMap (non-secret) and a
# Secret / Key Vault (the password) — never from a committed file.

DB_NAME=appdb
DB_USER=appuser
# Local-only placeholder. Use a strong, unique value in real environments.
DB_PASSWORD=changeme-local-only
