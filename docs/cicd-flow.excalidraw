      "id": "jdept",
      "type": "text",
      "x": 768,
      "y": 338,
      "width": 324,
      "height": 159,
      "text": "JOB  deploy               needs: push-images\nif: push→main OR tag\n\n•  azure/login → az aks get-credentials\n•  kubectl set image ...=<acr>/app:<sha>\n•  kubectl rollout status  (waits, auto-fail)\n[ MOCK=true → kubectl apply --dry-run=server ]",
      "fontSize": 12.5,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "jdep",
      "originalText": "JOB  deploy               needs: push-images\nif: push→main OR tag\n\n•  azure/login → az aks get-credentials\n•  kubectl set image ...=<acr>/app:<sha>\n•  kubectl rollout status  (waits, auto-fail)\n[ MOCK=true → kubectl apply --dry-run=server ]",
      "lineHeight": 1.25,
      "baseline": 12.5
    },
