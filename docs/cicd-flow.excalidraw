      "id": "jpusht",
      "type": "text",
      "x": 768,
      "y": 158,
      "width": 324,
      "height": 134,
      "text": "JOB  push-images        needs: build-and-test\nif: (push→main OR tag) AND env.MOCK != 'true'\n\n•  azure/login (OIDC) → az acr login\n•  docker push <acr>/app:<sha>\n[ MOCK=true → echo & skip real push ]",
      "fontSize": 12.5,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "jpush",
      "originalText": "JOB  push-images        needs: build-and-test\nif: (push→main OR tag) AND env.MOCK != 'true'\n\n•  azure/login (OIDC) → az acr login\n•  docker push <acr>/app:<sha>\n[ MOCK=true → echo & skip real push ]",
      "lineHeight": 1.25,
      "baseline": 12.5
    },
